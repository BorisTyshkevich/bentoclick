<?xml version="1.0"?>
<!--
  bentoclick — HTTP handlers for the dashboard SPA.

  Apply as a ClickHouse config.d fragment. The fragment is named
  `bentoclick.xml` so it is recognisable at a glance in a
  `ls /etc/clickhouse-server/config.d/` listing. On the demo cluster,
  push via:
    acmctl setting create <cluster-id> bentoclick @handlers/bentoclick.xml
    acmctl cluster push <cluster-id>

  All referenced assets live under /var/lib/clickhouse/user_files/dash/ and
  are written there by install.sh via `INSERT INTO FUNCTION file('dash/<name>', 'RawBLOB', 'String')`.

  Note: ClickHouse loads only the last <http_handlers> block across config.d.
  If another fragment on this cluster also defines <http_handlers> (e.g. an
  OAuth callback handler), install.sh merges the two before pushing.

  Routes:
    GET /app                          → SPA shell
    GET /v/<owner>/<slug>             → SPA shell (route handled client-side)
    GET /lib/v1/spa.js                → SPA bootstrap JS (ES module)
    GET /lib/v1/spa-helpers.js        → pure helpers imported by spa.js
    GET /lib/v1/dash.js               → shared dashboard runtime (window.DASH.*)
    GET /lib/v1/charts.js             → SVG chart primitives imported by dash.js
    GET /lib/v1/dash-theme.css        → shared dashboard theme tokens
    GET /lib/v1/tweaks.js             → floating display-tweaks panel module
    GET /oauth/callback               → OAuth code → token exchange page
    GET /config.json                  → runtime config (MCP/CH URLs, branding)
    GET /oauth/client.json            → CIMD client metadata document
-->
<clickhouse>
    <http_handlers>
        <!-- SPA shell. Route parsing happens in spa.js. -->
        <rule>
            <url><![CDATA[regex:^(/app|/v/[^/]+/[^/]+)/?(\?.*)?$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>text/html; charset=UTF-8</content_type>
                <http_response_headers>
                    <!-- connect-src is intentionally narrow: the shell calls
                         same-origin (config.json, CH) and the MCP for OAuth
                         discovery. The dashboard iframe (srcdoc, sandboxed,
                         null origin) inherits this CSP — `'self'` evaluates
                         to nothing inside the iframe, so a malicious
                         dashboard can't browser-side-exfil via fetch() to an
                         arbitrary HTTPS endpoint. CH_FETCH still works
                         because it's postMessage, not a network connect.
                         At install time ${MCP_ORIGIN} is substituted to the
                         deployment's MCP scheme+host. -->
                    <Content-Security-Policy>default-src 'none';script-src 'self' 'unsafe-inline' 'unsafe-eval' https:;style-src 'self' 'unsafe-inline' https:;img-src 'self' data: https:;font-src 'self' data: https:;connect-src 'self' ${MCP_ORIGIN};frame-src 'self';object-src 'none';base-uri 'self'</Content-Security-Policy>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/spa.html</response_content>
            </handler>
        </rule>

        <!-- SPA bootstrap JS. Versioned alongside the shell. -->
        <rule>
            <url><![CDATA[regex:^/lib/v1/spa\.js$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/javascript; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/spa.js</response_content>
            </handler>
        </rule>

        <!-- OAuth callback page. PKCE verifier comes from sessionStorage; this
             page exchanges the auth code for a bearer and posts back to the
             opener. CSP is tighter than the SPA shell since no third-party
             scripts run here. -->
        <rule>
            <url><![CDATA[regex:^/oauth/callback(\?.*)?$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <status>200</status>
                <content_type>text/html; charset=UTF-8</content_type>
                <http_response_headers>
                    <Content-Security-Policy>default-src 'none';script-src 'self' 'unsafe-inline';style-src 'self' 'unsafe-inline';connect-src https:;base-uri 'self';object-src 'none';frame-ancestors 'none'</Content-Security-Policy>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/oauth-callback.html</response_content>
            </handler>
        </rule>

        <!-- Shared dashboard runtime + theme. Cached. Versioned via /lib/vN/. -->
        <rule>
            <url><![CDATA[regex:^/lib/v1/dash\.js$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/javascript; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>public, max-age=300, stale-while-revalidate=3600</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/dash.js</response_content>
            </handler>
        </rule>

        <!-- charts.js — sibling SVG primitives that dash.js imports.
             Served as a sibling so the ESM static import in dash.js
             resolves; the iframe boot path fetches it explicitly via
             synthesizeSpecWrapper(). -->
        <rule>
            <url><![CDATA[regex:^/lib/v1/charts\.js$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/javascript; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>public, max-age=300, stale-while-revalidate=3600</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/charts.js</response_content>
            </handler>
        </rule>

        <!-- spa-helpers.js — pure helpers (escape, fmt, OAuth-safe
             utilities) imported by spa.js as ES module. Extracted so
             tests can import them directly and v8 coverage tracks the
             actual file (source-slicing tests don't count). -->
        <rule>
            <url><![CDATA[regex:^/lib/v1/spa-helpers\.js$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/javascript; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/spa-helpers.js</response_content>
            </handler>
        </rule>

        <rule>
            <url><![CDATA[regex:^/lib/v1/dash-theme\.css$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>text/css; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>public, max-age=300, stale-while-revalidate=3600</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/dash-theme.css</response_content>
            </handler>
        </rule>

        <!-- tweaks.js — floating display-tweaks panel (accent / theme /
             density / narrative). Imported by spa.js as an ES module;
             not part of the dashboard iframe srcdoc bundle. no-store
             since edits are frequent during UI work. -->
        <rule>
            <url><![CDATA[regex:^/lib/v1/tweaks\.js$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/javascript; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/tweaks.js</response_content>
            </handler>
        </rule>

        <!-- Runtime config: MCP/CH URLs, email domain, branding, lib version.
             Re-config is `INSERT INTO FUNCTION file('dash/config.json', ...)`
             plus an immediate browser refresh (no-store). -->
        <rule>
            <url><![CDATA[regex:^/config\.json$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/json; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/config.json</response_content>
            </handler>
        </rule>

        <!-- CIMD client metadata document. The SPA uses this URL as its
             client_id when calling /oauth/authorize on the AS. -->
        <rule>
            <url><![CDATA[regex:^/oauth/client\.json$]]></url>
            <methods>GET</methods>
            <handler>
                <type>static</type>
                <content_type>application/json; charset=UTF-8</content_type>
                <http_response_headers>
                    <Cache-Control>no-store</Cache-Control>
                </http_response_headers>
                <response_content>file://dash/client.json</response_content>
            </handler>
        </rule>

        <defaults/>
    </http_handlers>
</clickhouse>
